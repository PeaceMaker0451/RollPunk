; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RollPunk"
config/version="0.1.0"
run/main_scene="res://Scenes/Main.tscn"
run/print_header=false
config/use_custom_user_dir=true
config/features=PackedStringArray("4.4", "C#", "GL Compatibility")
run/delta_smoothing=false
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/image="res://Sprites/logo.png"
config/icon="res://Sprites/logo.png"
config/windows_native_icon="res://Sprites/logo.ico"

[display]

window/size/viewport_width=800
window/size/viewport_height=600
window/size/transparent=true
window/subwindows/embed_subwindows=false
window/stretch/aspect="ignore"
window/handheld/orientation=4
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="RollPunk"

[editor]

export/convert_text_resources_to_binary=false

[editor_plugins]

enabled=PackedStringArray()

[gui]

common/snap_controls_to_pixels=false
theme/custom="res://Style/RollPunkMainTheme.tres"

[internationalization]

locale/translations=PackedStringArray("res://Localization/LocalizationFileMain.en.translation", "res://Localization/LocalizationFileMain.ru.translation")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
